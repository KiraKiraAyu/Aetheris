HTTP_ADDR=:8080
DATABASE_URL=aetheris.db
QUEUE_TYPE=db
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional API authentication. Format: api-key:tenant-id,api-key-2:tenant-id-2
# If empty, API auth is disabled for local development.
API_KEYS=
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5178,http://localhost:5178
REQUEST_MAX_BYTES=1048576
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=600

QUEUE_NAME=notifications
ASYNQ_UNIQUE_TTL=5m
WORKER_CONCURRENCY=10
